/**
 * Example Jenkinsfile demonstrating MCP Agent plugin usage.
 *
 * The plugin automatically analyzes build failures using AI (Claude via AWS Bedrock).
 * It runs 4 MCP agents in parallel to gather context from Jenkins, BitBucket,
 * Kubernetes, and JFrog, then generates a root cause analysis report.
 *
 * Prerequisites:
 *   1. Install the MCP Agent plugin on your Jenkins instance
 *   2. Configure global settings in Manage Jenkins -> Configure System
 *   3. Add the post-failure step to your pipeline as shown below
 */

pipeline {
    agent any

    environment {
        // These are automatically picked up by the MCP Agent plugin
        GIT_BRANCH = "${env.BRANCH_NAME ?: 'main'}"
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Build') {
            steps {
                sh 'mvn clean compile -B'
            }
        }

        stage('Test') {
            steps {
                sh 'mvn test -B'
            }
            post {
                always {
                    junit allowEmptyResults: true, testResults: '**/target/surefire-reports/*.xml'
                }
            }
        }

        stage('Package') {
            steps {
                sh 'mvn package -DskipTests -B'
            }
        }

        stage('Deploy') {
            when {
                branch 'main'
            }
            steps {
                sh 'mvn deploy -DskipTests -B'
            }
        }
    }

    post {
        failure {
            // Basic usage - uses global configuration
            mcpAnalyze()
        }

        // Alternative: with explicit repository configuration
        // failure {
        //     mcpAnalyze(
        //         repositories: [
        //             [name: 'E3', workspace: 'E3', branch: env.GIT_BRANCH],
        //             [name: 'AP', workspace: 'E3', branch: env.GIT_BRANCH]
        //         ]
        //     )
        // }
    }
}
