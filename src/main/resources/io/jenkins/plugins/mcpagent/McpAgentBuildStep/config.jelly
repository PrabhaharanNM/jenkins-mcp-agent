<?jelly escape-by-default='true'?>
<j:jelly xmlns:j="jelly:core" xmlns:f="/lib/form">

    <f:section title="MCP Agent - Repository Configuration">
        <f:entry title="Repository Configurations"
                 description="Configure the repositories to analyze when a build failure occurs.">
            <f:repeatableProperty field="repositories" minimum="1">
                <f:entry title="Repository Name" field="name">
                    <f:textbox />
                </f:entry>
                <f:entry title="Workspace" field="workspace">
                    <f:textbox />
                </f:entry>
                <f:entry title="Branch" field="branch">
                    <f:textbox default="main" />
                </f:entry>
            </f:repeatableProperty>
        </f:entry>
    </f:section>

</j:jelly>
